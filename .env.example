# Copy to .env.local for local dev. These are PUBLIC values (safe to ship in the
# PWA bundle); Row-Level Security is what actually protects the data.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Synthetic email domain used to map usernames -> Supabase Auth emails.
# Users only ever type a username + password.
VITE_USERNAME_EMAIL_DOMAIN=boylebingo.local
